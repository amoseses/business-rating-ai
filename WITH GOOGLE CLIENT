function el(id) { return document.getElementById(id); }
function clamp(x, lo, hi) { return Math.max(lo, Math.min(hi, x)); }
function round(x) { return Math.round(Number.isFinite(x) ? x : 0); }
function textLower(text) { return String(text || '').toLowerCase(); }
function tokenize(text) { return textLower(text).replace(/[^a-z0-9%$\.\s-]/g, ' ').split(/\s+/).filter(Boolean); }
function countMatches(text, arr) { const low = textLower(text); return arr.reduce((n, term) => n + (low.includes(term) ? 1 : 0), 0); }
function moneyCount(text) { return (String(text).match(/\$\s?\d|\d+\s?(k|m|b|million|billion)|\d+%/gi) || []).length; }
function sentenceCount(text) { return Math.max(1, (String(text).match(/[.!?]+/g) || []).length); }
function wordCount(text) { return tokenize(text).length; }
function uniqueRatio(tokens) { return tokens.length ? new Set(tokens).size / tokens.length : 0; }

function analyzeInputQuality(text) {
  const raw = String(text || '').trim();
  const tokens = tokenize(raw);
  const letters = (raw.match(/[a-z]/gi) || []).length;
  const vowels = (raw.match(/[aeiou]/gi) || []).length;
  const spaces = (raw.match(/\s/g) || []).length;
  const wc = tokens.length;
  const vowelRatio = letters ? vowels / letters : 0;
  const knownBusinessHits = Object.keys(TERMS).filter(k => !['hype','vague'].includes(k)).reduce((sum,k)=>sum+countMatches(raw, TERMS[k]),0);
  const weirdSingleToken = wc <= 2 && letters >= 5 && spaces === 0 && knownBusinessHits === 0;
  const tooShort = wc < 18;
  const gibberish = weirdSingleToken || (letters > 0 && (vowelRatio < 0.18 || vowelRatio > 0.72) && knownBusinessHits === 0 && wc < 8);
  const repeated = tokens.length > 8 && uniqueRatio(tokens) < 0.35;
  let quality = 100;
  if (tooShort) quality -= 45;
  if (wc < 8) quality -= 30;
  if (gibberish) quality -= 65;
  if (repeated) quality -= 35;
  if (knownBusinessHits === 0) quality -= 30;
  return { wordCount: wc, tooShort, gibberish, repeated, knownBusinessHits, quality: clamp(quality, 0, 100), lowSignal: quality < 45 || gibberish };
}

function featureVector(text) {
  const wc = wordCount(text);
  const sc = sentenceCount(text);
  const avgSentence = wc / sc;
  const metrics = moneyCount(text);
  const p = countMatches(text, TERMS.problem);
  const s = countMatches(text, TERMS.solution);
  const m = countMatches(text, TERMS.market);
  const b = countMatches(text, TERMS.business);
  const t = countMatches(text, TERMS.traction);
  const moat = countMatches(text, TERMS.moat);
  const team = countMatches(text, TERMS.team);
  const ask = countMatches(text, TERMS.ask);
  const hype = countMatches(text, TERMS.hype);
  const vague = countMatches(text, TERMS.vague);
  const structureCount = [p,s,m,b,t,moat,team,ask].filter(x => x > 0).length;
  const wordScore = wc < 35 ? wc / 35 : wc <= 220 ? 1 : clamp(1 - ((wc - 220) / 420), .35, 1);
  const clarity = clamp(1 - Math.abs(avgSentence - 19) / 28, 0, 1);
  const specificity = clamp((metrics * .18) + (t > 0 ? .22 : 0) + (b > 0 ? .16 : 0) + (m > 0 ? .13 : 0) + (moat > 0 ? .13 : 0) + (ask > 0 ? .08 : 0), 0, 1);
  return {
    wordScore,
    problem: clamp(p/3,0,1), solution: clamp(s/3,0,1), market: clamp(m/3,0,1), business: clamp(b/2,0,1), traction: clamp(t/3,0,1), moat: clamp(moat/2,0,1), team: clamp(team/2,0,1), ask: clamp(ask/2,0,1),
    metrics: clamp(metrics/5,0,1), specificity, structure: structureCount/8, clarity,
    hypePenalty: clamp(hype/5,0,1), vaguePenalty: clamp(vague/4,0,1)
  };
}

