  el('scoreNumber').textContent = '--';
  el('resultHeadline').textContent = 'Pro is under construction';
  el('memoText').textContent = 'This mode is reserved for your future external LLM/API. Basic and Plus are fully usable in this free beta.';
  el('tagRow').innerHTML = '<span class="tag warn">Future LLM/API</span><span class="tag">No call made</span>';
  el('sectionScores').innerHTML = '';
  fillList('whyList', ['Pro intentionally does not call any external service yet.', 'Add your hosted LLM later inside the Pro analysis function.']);
  fillList('redFlags', ['Under construction.']);
  fillList('missingProof', ['Use Basic or Plus to grade pitches now.']);
  fillList('questionsList', ['What external model will Pro use?', 'Will Pro save pitch history server-side?']);
  fillList('deckBullets', ['Pro output placeholder.']);
  fillList('nearestList', ['No model examples shown in Pro placeholder.']);
  el('rewriteBox').classList.remove('show');
}

function renderAnalysis(a, basicCompare) {
  el('results').classList.add('show');
  el('scoreNumber').textContent = a.score;
  el('resultHeadline').textContent = `${a.label}`;
  el('memoText').textContent = a.memo;
  const tagClass = a.score >= 75 ? 'good' : a.score >= 50 ? 'warn' : 'bad';
  el('tagRow').innerHTML = `<span class="tag ${tagClass}">${a.mode === 'plus' ? 'Plus offline model' : 'Basic rubric'}</span><span class="tag">Confidence: ${a.confidence}</span>${basicCompare ? `<span class="tag">Basic: ${basicCompare.score}</span><span class="tag good">Plus: ${a.score}</span>` : ''}`;
  renderSections(a.sections);
  fillList('whyList', a.why);
  fillList('redFlags', a.redFlags);
  fillList('missingProof', a.missingProof);
  fillList('questionsList', a.questions);
  fillList('deckBullets', a.deck);
  const near = a.neighbors && a.neighbors.length ? a.neighbors.map(n => `${n.industry} ${n.stage}: ${n.rating}/100 match (${Math.round(n.similarity*100)}%)`) : ['Available in Plus mode after analysis.'];
  fillList('nearestList', near);
}

function renderSections(sections) {
  el('sectionScores').innerHTML = Object.entries(sections).map(([name,value]) => `<div class="section-score"><div class="section-name">${escapeHTML(name)}</div><div class="bar"><span style="width:${clamp(value,0,100)}%"></span></div><div class="section-num">${value}</div></div>`).join('');
}

function fillList(id, items) {
  el(id).innerHTML = (items && items.length ? items : ['No issues found.']).map(item => `<li>${escapeHTML(item)}</li>`).join('');
}

function escapeHTML(str) { return String(str).replace(/[&<>'"]/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[ch])); }

function loadSample() {
  el('pitchTitle').value = AIRBNB_SAMPLE.title;
  el('industrySelect').value = AIRBNB_SAMPLE.industry;
  el('stageSelect').value = AIRBNB_SAMPLE.stage;
  el('pitchText').value = AIRBNB_SAMPLE.text;
  setMode('plus');
  showToast('Loaded the Airbnb-style sample.');
}

function openSource() { window.open(SAMPLE_SOURCE_URL, '_blank', 'noopener,noreferrer'); }
function scrollApp() { el('app').scrollIntoView({behavior:'smooth', block:'start'}); }
function clearPitch() { el('pitchTitle').value=''; el('pitchText').value=''; el('results').classList.remove('show'); el('rewriteBox').classList.remove('show'); showToast('Cleared.'); }

function rewritePitch() {
  const pitch = getPitch();
  if (!pitch) return showToast('Paste a pitch first.');
  const a = currentMode === 'plus' ? analyzePlus() : analyzeBasic();
  const industry = el('industrySelect').value;
  const stage = el('stageSelect').value;
  const missing = a.missingProof.slice(0,3).join(' ');
  latestRewrite = `We help a focused group of ${industry} customers solve a painful operational problem with a product that is easier, faster, and more measurable than the current workaround.\n\nThe sharper version of this pitch should lead with the customer pain, explain the product in one sentence, and then prove demand with concrete evidence. For this ${stage} stage company, the strongest next version should include traction such as users, revenue, paid pilots, retention, booking volume, or signed LOIs.\n\nBusiness model: state whether revenue comes from subscription, commission, usage-based pricing, or services, and include one metric that shows pricing power or margin potential.\n\nMoat: explain why the company gets harder to copy over time through data, workflow integration, network effects, brand trust, or distribution.\n\nNext raise: state the amount being raised and the milestone it unlocks. ${missing}`;
  el('rewriteText').textContent = latestRewrite;
  el('rewriteScore').textContent = 'Click “Score rewrite” to estimate the improved version.';
  el('rewriteBox').classList.add('show');
  showToast('Rewrite generated.');
}

function scoreRewrite() {
  if (!latestRewrite) return showToast('Generate a rewrite first.');
  const oldText = el('pitchText').value;
  el('pitchText').value = latestRewrite;
  const a = currentMode === 'plus' ? analyzePlus() : analyzeBasic();
  el('pitchText').value = oldText;
  el('rewriteScore').textContent = `Estimated rewritten score: ${a.score}/100 (${a.label}).`;
}

function showToast(msg) {
  const t = el('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(showToast._timer);
  showToast._timer = setTimeout(() => t.classList.remove('show'), 2300);
}

function saveHistory(a, basic) {
  try {
    const key = 'astrapitch_history_v1';
    const history = JSON.parse(localStorage.getItem(key) || '[]');
    history.unshift({ title:getTitle(), mode:a.mode, score:a.score, label:a.label, basicScore:basic ? basic.score : null, time:new Date().toLocaleString() });
    localStorage.setItem(key, JSON.stringify(history.slice(0,12)));
    renderHistory();
  } catch (e) { /* localStorage can fail in private contexts */ }
}

function renderHistory() {
  let history = [];
  try { history = JSON.parse(localStorage.getItem('astrapitch_history_v1') || '[]'); } catch(e) {}
  el('historyList').innerHTML = history.length ? history.map(h => `<div class="history-item"><strong>${escapeHTML(h.title)}</strong><span class="muted">${escapeHTML(h.mode)} · ${h.score}/100 · ${escapeHTML(h.label)}${h.basicScore !== null ? ` · Basic ${h.basicScore}` : ''}<br>${escapeHTML(h.time)}</span></div>`).join('') : '<p class="muted">No analyses saved yet.</p>';
}

function toggleHistory() { el('historyPanel').classList.toggle('show'); renderHistory(); }
function clearHistory() { try { localStorage.removeItem('astrapitch_history_v1'); } catch(e) {} renderHistory(); showToast('History cleared.'); }

function boot() {
  const rows = buildTrainingDatabase();
  model = trainModel(rows);
  el('modelStatus').textContent = `${rows.length.toLocaleString()} embedded examples loaded`;
  
  // Button event listeners with error checking
  const bindings = [
    ['basicTab','click',()=>setMode('basic')], 
    ['plusTab','click',()=>setMode('plus')], 
    ['proTab','click',()=>setMode('pro')],
    ['analyzeBtn','click',runAnalysis], 
    ['topAnalyzeBtn','click',()=>{scrollApp(); runAnalysis();}], 
    ['compareBtn','click',compareBasicPlus],
    ['rewriteBtn','click',rewritePitch], 
    ['scoreRewriteBtn','click',scoreRewrite], 
    ['clearBtn','click',clearPitch],
    ['sampleBtn','click',loadSample], 
    ['heroSampleBtn','click',()=>{loadSample(); scrollApp();}], 
    ['heroStartBtn','click',scrollApp], 
    ['sourceBtn','click',openSource],
    ['historyBtn','click',toggleHistory], 
    ['clearHistoryBtn','click',clearHistory],
    ['continueGuestBtn','click',()=>{ hideEntryOverlay(); showToast('Entered free beta.'); }],
    ['entryCloseBtn','click',hideEntryOverlay]
  ];
  
  // Attach all event listeners and log any missing elements
  bindings.forEach(([id, evt, fn]) => { 
    const node = el(id); 
    if (node) {
      node.addEventListener(evt, fn);
    } else {
      console.warn(`Button element not found: ${id}`);
    }
  });
  
  renderHistory();
  setMode('basic');
  el('statusText').textContent = 'Ready. No external API calls.';
  showEntryOverlay();
  initGoogleClient();
}

// Boot function with proper DOMContentLoaded handling
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot);
} else {
  boot();
}
</script>
</body>
</html>
