  business: ['pricing','subscription','commission','margin','revenue model','per seat','per location','usage-based','takes a','transaction','saas'],
  moat: ['moat','defensible','proprietary','unique','advantage','network effects','data advantage','switching costs','integrations','patent'],
  team: ['founder','team','experience','built','domain','advisor','operator','technical','sales','background'],
  ask: ['raising','investment','capital','funding','round','ask','runway','hire','scale','expand'],
  hype: ['revolutionary','game-changing','world-changing','disrupt','everyone','massive','huge','best','leading','ultimate','next generation'],
  vague: ['many industries','everyone','businesses','users','things','stuff','very large','soon','eventually','figuring out','all-in-one']
};

const SECTION_NAMES = ['Problem','Solution','Market','Business model','Traction','Moat','Team','Ask'];
