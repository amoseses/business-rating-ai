<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AstraPitch AI — Working Offline Beta</title>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<style>
  :root {
    --bg:#07111f;
    --bg2:#0d1830;
    --card:rgba(13,22,41,.82);
    --card2:rgba(20,31,55,.92);
    --line:rgba(125,211,252,.16);
    --line2:rgba(255,255,255,.08);
    --text:#eef6ff;
    --muted:#9eb0cb;
    --faint:#6f809d;
    --blue:#60d8ff;
    --violet:#9b72ff;
    --green:#22c55e;
    --amber:#f59e0b;
    --red:#fb7185;
    --shadow:0 24px 90px rgba(0,0,0,.38);
    --radius:22px;
    --sans:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --mono:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  * { box-sizing:border-box; margin:0; padding:0; }
  html { scroll-behavior:smooth; }
  body {
    min-height:100vh;
    font-family:var(--sans);
    color:var(--text);
    background:
      radial-gradient(circle at 12% 8%, rgba(96,216,255,.16), transparent 30%),
      radial-gradient(circle at 86% 6%, rgba(155,114,255,.16), transparent 28%),
      radial-gradient(circle at 50% 110%, rgba(34,197,94,.08), transparent 38%),
      linear-gradient(180deg, #050b14 0%, var(--bg) 36%, #091324 100%);
    overflow-x:hidden;
  }
  body:before {
    content:"";
    position:fixed;
    inset:0;
    background-image:
      radial-gradient(1px 1px at 30px 80px, rgba(255,255,255,.30), transparent),
      radial-gradient(1px 1px at 160px 190px, rgba(255,255,255,.18), transparent),
      radial-gradient(1px 1px at 310px 120px, rgba(255,255,255,.24), transparent),
      radial-gradient(1px 1px at 500px 240px, rgba(255,255,255,.18), transparent);
    background-size:540px 300px;
    opacity:.36;
    z-index:-2;
  }
  .shell { width:min(1180px, calc(100% - 32px)); margin:0 auto; }
  .topbar {
    position:sticky;
    top:0;
    z-index:10;
    backdrop-filter: blur(18px);
    background:rgba(5,11,20,.72);
    border-bottom:1px solid var(--line2);
  }
  .nav { height:74px; display:flex; align-items:center; justify-content:space-between; gap:20px; }
  .brand { display:flex; align-items:center; gap:12px; font-weight:850; letter-spacing:.4px; }
  .mark {
    width:38px; height:38px; border-radius:14px;
    display:grid; place-items:center;
    background:linear-gradient(135deg, var(--blue), var(--violet));
    color:#06101e;
    font-weight:950;
    box-shadow:0 12px 32px rgba(96,216,255,.24);
  }
  .nav-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
  .pill {
    border:1px solid var(--line);
    background:rgba(255,255,255,.045);
    color:var(--muted);
    border-radius:999px;
    padding:9px 13px;
    font-size:.88rem;
  }
  .hero { padding:56px 0 26px; display:grid; grid-template-columns:1.15fr .85fr; gap:28px; align-items:center; }
  .eyebrow { color:var(--blue); font-weight:800; letter-spacing:.12em; font-size:.75rem; text-transform:uppercase; margin-bottom:14px; }
  h1 { font-size:clamp(2.3rem, 5vw, 5.6rem); line-height:.95; letter-spacing:-.07em; max-width:790px; }
  .gradient { background:linear-gradient(135deg, #fff, var(--blue), var(--violet)); -webkit-background-clip:text; background-clip:text; color:transparent; }
  .hero p { margin-top:20px; color:var(--muted); font-size:1.08rem; max-width:700px; }
  .hero-card {
    padding:22px;
    border:1px solid var(--line);
    background:linear-gradient(180deg, rgba(15,26,49,.86), rgba(11,18,34,.78));
    border-radius:var(--radius);
    box-shadow:var(--shadow);
  }
  .mini-row { display:flex; justify-content:space-between; gap:18px; padding:13px 0; border-bottom:1px solid var(--line2); }
  .mini-row:last-child { border-bottom:0; }
  .mini-label { color:var(--faint); font-size:.83rem; }
  .mini-value { font-weight:850; color:#fff; text-align:right; }
  .section { padding:28px 0 80px; }
  .workspace {
    display:grid;
    grid-template-columns:360px 1fr;
    gap:22px;
    align-items:start;
  }
  .panel {
    border:1px solid var(--line);
    background:linear-gradient(180deg, var(--card), rgba(8,15,28,.82));
    border-radius:var(--radius);
    box-shadow:var(--shadow);
  }
  .panel-inner { padding:22px; }
  .panel-title { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:16px; }
  .panel-title h2, .panel-title h3 { font-size:1.02rem; letter-spacing:-.02em; }
  label { display:block; color:var(--muted); font-size:.87rem; margin:15px 0 7px; }
  input, textarea, select {
    width:100%;
    border:1px solid rgba(125,211,252,.16);
    background:rgba(6,12,23,.72);
    color:var(--text);
    border-radius:15px;
    padding:12px 13px;
    font:inherit;
    outline:none;
    transition:border-color .18s, box-shadow .18s, background .18s;
  }
  textarea { min-height:260px; resize:vertical; line-height:1.55; }
  input:focus, textarea:focus, select:focus { border-color:rgba(96,216,255,.62); box-shadow:0 0 0 4px rgba(96,216,255,.10); }
  .tabs { display:grid; grid-template-columns:1fr; gap:10px; margin:10px 0 18px; }
  .tab-btn {
    width:100%;
    text-align:left;
    cursor:pointer;
    border:1px solid var(--line2);
    color:var(--muted);
    background:rgba(255,255,255,.035);
    border-radius:16px;
    padding:14px;
    transition:.18s ease;
  }
  .tab-btn strong { display:block; color:var(--text); margin-bottom:2px; }
  .tab-btn span { font-size:.83rem; }
  .tab-btn.active {
    border-color:rgba(96,216,255,.54);
    background:linear-gradient(135deg, rgba(96,216,255,.16), rgba(155,114,255,.11));
    box-shadow:0 14px 36px rgba(96,216,255,.08);
  }
  .btn-row { display:flex; gap:10px; flex-wrap:wrap; margin-top:15px; }
  button, .link-btn {
    border:0;
    cursor:pointer;
    border-radius:14px;
    padding:12px 14px;
    color:var(--text);
    font-weight:800;
    font-family:inherit;
    transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease, background .16s ease;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
  }
  button:hover, .link-btn:hover { transform:translateY(-1px); }
  .btn-primary { background:linear-gradient(135deg, var(--blue), var(--violet)); color:#06101e; box-shadow:0 16px 36px rgba(96,216,255,.22); }
  .btn-secondary { background:rgba(255,255,255,.055); border:1px solid var(--line); color:var(--text); }
  .btn-ghost { background:transparent; border:1px solid var(--line2); color:var(--muted); }
  .btn-danger { background:rgba(251,113,133,.12); border:1px solid rgba(251,113,133,.24); color:#fecdd3; }
  .wide { width:100%; }
  .input-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .status-line {
    display:flex;
    align-items:center;
    gap:8px;
    margin-top:14px;
    color:var(--muted);
    font-size:.9rem;
  }
  .dot { width:9px; height:9px; border-radius:999px; background:var(--green); box-shadow:0 0 22px rgba(34,197,94,.8); flex:0 0 auto; }
  .results { display:none; margin-top:20px; }
  .results.show { display:block; }
  .score-hero {
    display:grid;
    grid-template-columns:170px 1fr;
    gap:20px;
    align-items:center;
    padding:22px;
    border:1px solid var(--line);
    background:linear-gradient(135deg, rgba(96,216,255,.12), rgba(155,114,255,.10));
    border-radius:var(--radius);
  }
  .score-circle {
    width:148px;
    height:148px;
    border-radius:50%;
    display:grid;
    place-items:center;
    border:1px solid rgba(255,255,255,.14);
    background:radial-gradient(circle at 30% 25%, rgba(255,255,255,.20), transparent 34%), rgba(4,10,19,.56);
    box-shadow:inset 0 0 40px rgba(96,216,255,.10);
  }
  .score-circle span { font-size:2.7rem; font-weight:950; letter-spacing:-.06em; }
  .tag-row { display:flex; flex-wrap:wrap; gap:8px; margin:12px 0; }
  .tag { padding:7px 10px; border-radius:999px; border:1px solid var(--line2); background:rgba(255,255,255,.045); color:var(--muted); font-size:.82rem; }
  .tag.good { color:#bbf7d0; border-color:rgba(34,197,94,.25); background:rgba(34,197,94,.10); }
  .tag.warn { color:#fde68a; border-color:rgba(245,158,11,.25); background:rgba(245,158,11,.10); }
  .tag.bad { color:#fecdd3; border-color:rgba(251,113,133,.25); background:rgba(251,113,133,.10); }
  .memo { color:var(--muted); line-height:1.65; }
  .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px; }
  .grid-3 { display:grid; grid-template-columns:repeat(3, 1fr); gap:12px; margin-top:16px; }
  .small-card {
    padding:16px;
    border:1px solid var(--line2);
    background:rgba(255,255,255,.035);
    border-radius:18px;
  }
  .small-card h4 { font-size:.92rem; margin-bottom:9px; }
  .small-card p, .small-card li { color:var(--muted); font-size:.92rem; line-height:1.55; }
  ul.clean { list-style:none; display:grid; gap:8px; }
  ul.clean li { position:relative; padding-left:19px; }
  ul.clean li:before { content:""; position:absolute; left:0; top:.62em; width:7px; height:7px; border-radius:50%; background:var(--blue); }
  .section-score { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:10px 0; border-bottom:1px solid var(--line2); }
  .section-score:last-child { border-bottom:0; }
  .bar { flex:1; height:8px; border-radius:999px; background:rgba(255,255,255,.08); overflow:hidden; min-width:90px; }
  .bar span { display:block; height:100%; border-radius:999px; background:linear-gradient(90deg, var(--blue), var(--violet)); width:50%; }
  .section-name { min-width:112px; color:var(--muted); font-size:.88rem; }
  .section-num { width:36px; text-align:right; font-weight:850; }
  .rewrite-box { display:none; margin-top:16px; }
  .rewrite-box.show { display:block; }
  .rewrite-text {
    white-space:pre-wrap;
    color:#dceeff;
    line-height:1.65;
  }
  .source-note { color:var(--faint); font-size:.82rem; margin-top:8px; line-height:1.45; }
  .history { display:none; margin-top:16px; }
  .history.show { display:block; }
  .history-item { padding:12px; border:1px solid var(--line2); border-radius:14px; margin-top:10px; background:rgba(255,255,255,.03); }
  .history-item strong { display:block; margin-bottom:4px; }
  .toast { position:fixed; right:18px; bottom:18px; z-index:50; padding:13px 15px; border:1px solid var(--line); border-radius:16px; background:rgba(7,13,24,.92); color:var(--text); box-shadow:var(--shadow); display:none; max-width:320px; }
  .toast.show { display:block; animation:pop .18s ease; }
  @keyframes pop { from { transform:translateY(8px); opacity:0; } to { transform:none; opacity:1; } }
  .hidden { display:none !important; }
  .muted { color:var(--muted); }
  .mono { font-family:var(--mono); }
  @media (max-width: 960px) {
    .hero { grid-template-columns:1fr; padding-top:34px; }
    .workspace { grid-template-columns:1fr; }
    .grid-2, .grid-3, .score-hero { grid-template-columns:1fr; }
    .score-circle { width:130px; height:130px; }
  }

  .entry-overlay {
    position: fixed;
    inset: 0;
    z-index: 5000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 22px;
    background: rgba(3, 8, 18, .78);
    backdrop-filter: blur(18px);
  }
  .entry-overlay.show { display: flex; }
  .entry-card {
    width: min(560px, 100%);
    border: 1px solid rgba(125,211,252,.18);
    border-radius: 28px;
    background:
      radial-gradient(circle at 10% 0%, rgba(96,216,255,.18), transparent 36%),
      radial-gradient(circle at 92% 10%, rgba(155,114,255,.16), transparent 34%),
      rgba(10, 18, 34, .96);
    box-shadow: 0 30px 120px rgba(0,0,0,.52);
    padding: 28px;
  }
  .entry-top { display:flex; justify-content:space-between; align-items:flex-start; gap:16px; margin-bottom:18px; }
  .entry-title { font-size: clamp(1.8rem, 5vw, 3rem); line-height:1.02; letter-spacing:-.055em; margin: 10px 0 12px; }
  .entry-text { color: var(--muted); font-size: 1rem; max-width: 46ch; }
  .entry-close {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid var(--line2);
    background: rgba(255,255,255,.05);
    color: var(--text);
    cursor: pointer;
    font-size: 1.1rem;
  }
  .entry-actions {
    display:flex;
    flex-direction:column;
    gap:12px;
    margin-top:22px;
  }
  .google-shell {
    min-height: 44px;
    display:flex;
    align-items:center;
    justify-content:center;
    padding: 10px;
    border: 1px solid var(--line2);
    border-radius: 16px;
    background: rgba(255,255,255,.04);
  }
  .entry-note { color: var(--faint); font-size:.88rem; margin-top: 12px; }

  @media (max-width: 560px) {
    .nav { height:auto; padding:14px 0; align-items:flex-start; flex-direction:column; }
    .input-grid { grid-template-columns:1fr; }
    textarea { min-height:230px; }
  }
</style>
</head>
<body>

  <div class="entry-overlay show" id="entryOverlay" role="dialog" aria-modal="true" aria-labelledby="entryTitle">
    <div class="entry-card">
      <div class="entry-top">
        <div class="brand"><div class="mark">A</div><div>AstraPitch AI</div></div>
        <button class="entry-close" id="entryCloseBtn" type="button" aria-label="Close">×</button>
      </div>
      <div class="eyebrow">Free beta · Google client ready</div>
      <h1 class="entry-title" id="entryTitle">Start with AstraPitch.</h1>
      <p class="entry-text">Sign in with Google if available, or continue directly into the free beta. Basic and Plus stay free; Pro is still under construction.</p>
      <div class="entry-actions">
        <div class="google-shell"><div id="googleButton"><span class="source-note">Loading Google sign-in…</span></div></div>
        <button class="btn-primary" id="continueGuestBtn" type="button">Continue to app</button>
      </div>
      <p class="entry-note" id="entryStatus">Google sign-in requires localhost or HTTPS. The app still works without signing in.</p>
    </div>
  </div>

  <header class="topbar">
    <div class="shell nav">
      <div class="brand"><div class="mark">A</div><div>AstraPitch AI</div></div>
      <div class="nav-actions">
        <span class="pill" id="modelStatus">Loading offline model…</span>
        <span class="pill" id="loginStatus">Guest</span>
        <button class="btn-secondary" id="topAnalyzeBtn" type="button">Analyze</button>
      </div>
    </div>
  </header>

  <main class="shell">
    <section class="hero">
      <div>
        <div class="eyebrow">Free beta · offline model</div>
        <h1>Pitch grading that feels like an <span class="gradient">investor memo.</span></h1>
        <p>Test Basic, Plus, and Pro layouts without any paywall. Basic uses a simple rubric. Plus uses a trained offline pitch model built into the page. Pro is ready for your future external LLM, but it stays under construction for now.</p>
        <div class="btn-row">
          <button class="btn-primary" id="heroSampleBtn" type="button">Load strong sample</button>
          <button class="btn-secondary" id="heroStartBtn" type="button">Start analyzing</button>
        </div>
      </div>
      <aside class="hero-card">
        <div class="mini-row"><div><div class="mini-label">Basic</div><div class="mini-value">Rubric scorer</div></div><span class="tag good">Works now</span></div>
        <div class="mini-row"><div><div class="mini-label">Plus</div><div class="mini-value">Offline trained model</div></div><span class="tag good">Free beta</span></div>
        <div class="mini-row"><div><div class="mini-label">Pro</div><div class="mini-value">Future LLM/API</div></div><span class="tag warn">Under construction</span></div>
      </aside>
    </section>

    <section class="section" id="app">
      <div class="workspace">
        <aside class="panel">
          <div class="panel-inner">
            <div class="panel-title"><h2>Mode</h2></div>
            <div class="tabs">
              <button class="tab-btn active" id="basicTab" type="button"><strong>Basic</strong><span>Fast original-style grading.</span></button>
              <button class="tab-btn" id="plusTab" type="button"><strong>Plus</strong><span>Offline trained model, still free.</span></button>
              <button class="tab-btn" id="proTab" type="button"><strong>Pro</strong><span>Under construction.</span></button>
            </div>

            <label for="personaSelect">Investor lens</label>
            <select id="personaSelect">
              <option value="friendly">Friendly angel</option>
              <option value="seedvc" selected>Seed VC</option>
              <option value="b2b">Hard-nosed B2B investor</option>
              <option value="consumer">Consumer growth investor</option>
            </select>

            <label for="stageSelect">Stage</label>
            <select id="stageSelect">
              <option>Idea</option>
              <option selected>Pre-seed</option>
              <option>Seed</option>
              <option>Series A</option>
            </select>

            <label for="industrySelect">Industry</label>
            <select id="industrySelect">
              <option selected>Marketplace</option>
              <option>AI SaaS</option>
              <option>Fintech</option>
              <option>HealthTech</option>
              <option>EdTech</option>
              <option>ClimateTech</option>
              <option>Cybersecurity</option>
              <option>Robotics</option>
              <option>Logistics</option>
              <option>PropTech</option>
              <option>Consumer</option>
            </select>

            <div class="btn-row">
              <button class="btn-secondary wide" id="sampleBtn" type="button">Load Airbnb-style sample</button>
              <button class="btn-ghost wide" id="sourceBtn" type="button">Open sample source</button>
            </div>
            <p class="source-note">The sample is written in the style of Airbnb’s early marketplace pitch, using a public pitch-deck reference as the source link.</p>

            <div class="btn-row">
              <button class="btn-ghost" id="historyBtn" type="button">History</button>
              <button class="btn-danger" id="clearHistoryBtn" type="button">Clear history</button>
            </div>
          </div>
        </aside>

        <section>
          <div class="panel">
            <div class="panel-inner">
              <div class="panel-title"><h2>Pitch input</h2><span class="pill" id="activeModePill">Basic</span></div>
              <div class="input-grid">
                <div>
                  <label for="pitchTitle">Pitch title</label>
                  <input id="pitchTitle" placeholder="e.g., Airbnb seed pitch" />
                </div>
                <div>
                  <label for="inputType">Input type</label>
                  <select id="inputType">
                    <option>Elevator pitch</option>
                    <option selected>Fundraising pitch</option>
                    <option>Deck copy</option>
                    <option>Founder intro</option>
                  </select>
                </div>
              </div>

              <label for="pitchText">Pitch text</label>
              <textarea id="pitchText" placeholder="Paste your business pitch here. Be specific: problem, customer, solution, traction, market, business model, moat, team, and ask."></textarea>

              <div class="btn-row">
                <button class="btn-primary" id="analyzeBtn" type="button">Analyze pitch</button>
                <button class="btn-secondary" id="compareBtn" type="button">Compare Basic vs Plus</button>
                <button class="btn-secondary" id="rewriteBtn" type="button">Rewrite stronger</button>
                <button class="btn-ghost" id="clearBtn" type="button">Clear</button>
              </div>
              <div class="status-line"><span class="dot"></span><span id="statusText">Ready. No external API calls.</span></div>
            </div>
          </div>

          <div class="results" id="results">
            <div class="score-hero">
              <div class="score-circle"><span id="scoreNumber">--</span></div>
              <div>
                <div class="tag-row" id="tagRow"></div>
                <h2 id="resultHeadline">Analysis ready</h2>
                <p class="memo" id="memoText"></p>
              </div>
            </div>

            <div class="grid-2">
              <div class="small-card"><h4>Section scores</h4><div id="sectionScores"></div></div>
              <div class="small-card"><h4>Why this score?</h4><ul class="clean" id="whyList"></ul></div>
            </div>

            <div class="grid-3">
              <div class="small-card"><h4>Investor red flags</h4><ul class="clean" id="redFlags"></ul></div>
              <div class="small-card"><h4>Missing proof</h4><ul class="clean" id="missingProof"></ul></div>
              <div class="small-card"><h4>Investor questions</h4><ul class="clean" id="questionsList"></ul></div>
            </div>

            <div class="grid-2">
              <div class="small-card"><h4>10-slide deck bullets</h4><ul class="clean" id="deckBullets"></ul></div>
              <div class="small-card"><h4>Closest embedded examples</h4><ul class="clean" id="nearestList"></ul></div>
            </div>

            <div class="rewrite-box" id="rewriteBox">
              <div class="small-card">
                <div class="panel-title"><h3>Rewrite</h3><button class="btn-secondary" id="scoreRewriteBtn" type="button">Score rewrite</button></div>
                <div class="rewrite-text" id="rewriteText"></div>
                <p class="source-note" id="rewriteScore"></p>
              </div>
            </div>
          </div>

          <div class="history" id="historyPanel">
            <div class="small-card"><h4>Saved history</h4><div id="historyList"></div></div>
          </div>
        </section>
      </div>
    </section>
  </main>

  <div class="toast" id="toast"></div>

<script>
'use strict';

const SAMPLE_SOURCE_URL = 'https://www.failory.com/pitch-deck/airbnb';
const AIRBNB_SAMPLE = {
  title: 'Airbnb-style marketplace pitch',
  industry: 'Marketplace',
  stage: 'Seed',
  text: 'Airbnb lets travelers book rooms and spare spaces from local hosts instead of relying only on hotels. The problem is simple: during major events, hotels become expensive or sold out while many residents have unused space. Hosts earn money from space they already have, guests get more affordable and local places to stay, and Airbnb takes a commission on each booking. The marketplace creates trust through profiles, reviews, payments, and a simple booking flow. Early demand is strongest around conferences and high-compression travel events, giving us a focused go-to-market wedge. We are raising capital to grow host supply, increase booking volume, improve trust and safety, and become the default marketplace for unique short-term stays.'
};

