function solveLinearSystem(A, b) {
  const n = b.length;
  const M = A.map((row, i) => row.slice().concat([b[i]]));
  for (let col=0; col<n; col++) {
    let pivot = col;
    for (let r=col+1; r<n; r++) if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
    if (Math.abs(M[pivot][col]) < 1e-9) continue;
    [M[col], M[pivot]] = [M[pivot], M[col]];
    const div = M[col][col];
    for (let c=col; c<=n; c++) M[col][c] /= div;
    for (let r=0; r<n; r++) {
      if (r === col) continue;
      const factor = M[r][col];
      for (let c=col; c<=n; c++) M[r][c] -= factor * M[col][c];
    }
  }
  return M.map(row => row[n] || 0);
}

function trainModel(rows) {
  const X = rows.map(r => [1].concat(vectorToArray(featureVector(r.pitch))));
  const y = rows.map(r => r.rating / 100);
  const n = X[0].length;
  const lambda = 0.12;
  const XtX = Array.from({length:n}, () => Array(n).fill(0));
  const Xty = Array(n).fill(0);
  for (let i=0; i<X.length; i++) {
    for (let a=0; a<n; a++) {
      Xty[a] += X[i][a] * y[i];
      for (let b=0; b<n; b++) XtX[a][b] += X[i][a] * X[i][b];
    }
  }
  for (let i=1; i<n; i++) XtX[i][i] += lambda;
  const weights = solveLinearSystem(XtX, Xty);
  return { rows, weights };
}

function dot(a, b) { let s = 0; for (let i=0; i<a.length; i++) s += a[i] * b[i]; return s; }
function cosine(a, b) { const d = dot(a,b); const na = Math.sqrt(dot(a,a)); const nb = Math.sqrt(dot(b,b)); return (!na || !nb) ? 0 : d/(na*nb); }

function predictPlus(text) {
  const quality = analyzeInputQuality(text);
  if (quality.lowSignal) {
    const score = quality.gibberish ? 6 : clamp(12 + quality.wordCount, 8, 28);
    return buildAnalysis('plus', score, text, quality, null, []);
  }
  const f = featureVector(text);
  const x = [1].concat(vectorToArray(f));
  const learned = clamp(dot(model.weights, x) * 100, 1, 99);
  const neighbors = nearestExamples(text, 4);
  const neighborScore = neighbors.length ? neighbors.reduce((s,n)=>s + n.rating * n.similarity,0) / Math.max(0.001, neighbors.reduce((s,n)=>s+n.similarity,0)) : learned;
  const heuristic = basicScore(text);
  const score = clamp((learned * .50) + (neighborScore * .25) + (heuristic * .25), 1, 99);
  return buildAnalysis('plus', score, text, quality, f, neighbors);
}

function basicScore(text) {
  const quality = analyzeInputQuality(text);
  if (quality.lowSignal) return quality.gibberish ? 8 : clamp(14 + quality.wordCount, 8, 30);
  const f = featureVector(text);
  let score = 8;
  score += 13*f.problem + 12*f.solution + 11*f.market + 10*f.business + 16*f.traction + 9*f.moat + 8*f.team + 7*f.ask + 8*f.metrics + 8*f.clarity + 8*f.wordScore;
  score -= 10*f.hypePenalty + 12*f.vaguePenalty;
  return clamp(score, 1, 96);
}

function nearestExamples(text, k) {
  const input = vectorToArray(featureVector(text));
  return model.rows.map(row => ({...row, similarity: cosine(input, vectorToArray(featureVector(row.pitch))) }))
    .filter(x => Number.isFinite(x.similarity))
    .sort((a,b) => b.similarity - a.similarity)
    .slice(0,k);
}

function sectionScores(text) {
  const f = featureVector(text);
  return {
    Problem: round(f.problem*100),
    Solution: round(f.solution*100),
    Market: round(f.market*100),
    'Business model': round(f.business*100),
    Traction: round(f.traction*100),
    Moat: round(f.moat*100),
    Team: round(f.team*100),
    Ask: round(f.ask*100)
  };
}

function buildAnalysis(mode, rawScore, text, quality, f, neighbors) {
  const score = round(rawScore);
  const sections = sectionScores(text);
  const missing = Object.entries(sections).filter(([,v]) => v < 35).map(([k]) => k);
  const flags = [];
  const proof = [];
  if (quality.gibberish) flags.push('The input looks like random text rather than a business pitch.');
  if (quality.tooShort) flags.push('The pitch is too short to judge seriously.');
  if (sections.Traction < 35) { flags.push('Traction is weak or missing.'); proof.push('Add users, revenue, pilots, retention, bookings, or growth rate.'); }
  if (sections['Business model'] < 35) { flags.push('The revenue model is unclear.'); proof.push('State pricing, commission, subscription, margin, or transaction model.'); }
  if (sections.Market < 35) proof.push('Name the target customer, beachhead market, or TAM/SAM/SOM.');
  if (sections.Moat < 35) proof.push('Explain why competitors cannot easily copy this.');
  if (sections.Ask < 35) proof.push('State how much you are raising and what milestone the capital reaches.');
  if (!flags.length) flags.push('No major red flag, but investors will still pressure-test traction, market size, and defensibility.');
  if (!proof.length) proof.push('Add one harder metric: retention, CAC, payback period, gross margin, or contracted pipeline.');

  const label = score >= 85 ? 'Investor-ready' : score >= 70 ? 'Strong but improvable' : score >= 52 ? 'Promising but incomplete' : score >= 30 ? 'Early / weak' : 'Not pitch-ready';
  const confidence = quality.wordCount >= 90 && quality.knownBusinessHits >= 5 ? 'High' : quality.wordCount >= 45 ? 'Medium' : 'Low';
  const why = [];
  if (score >= 70) why.push('The pitch includes multiple investor-relevant signals instead of only generic claims.');
  if (sections.Problem >= 55 && sections.Solution >= 55) why.push('Problem and solution are both identifiable.');
  if (sections.Traction >= 55) why.push('There is some evidence of market pull or early validation.');
  if (sections.Traction < 35) why.push('Score is capped because traction/proof is missing or vague.');
  if (sections.Moat < 35) why.push('Defensibility is not yet clear enough for a strong investor score.');
  if (quality.gibberish || quality.tooShort) why.push('Low-signal input triggered the quality guardrail.');
  if (!why.length) why.push('The score comes from section coverage, specificity, metrics, and clarity.');

  const persona = el('personaSelect') ? el('personaSelect').value : 'seedvc';
  const memo = makeMemo(score, label, sections, persona, mode, confidence);
  const questions = makeQuestions(sections, persona);
  const deck = makeDeckBullets(text, sections);
  return { mode, score, label, confidence, memo, sections, redFlags:flags, missingProof:proof, why, questions, deck, neighbors: neighbors || [] };
}

function makeMemo(score, label, sections, persona, mode, confidence) {
  const lens = {
    friendly:'An angel investor would likely focus on whether the founder story and customer pain feel credible.',
    seedvc:'A seed VC would focus on whether this can become a venture-scale company with proof of pull.',
    b2b:'A B2B investor would pressure-test buyer urgency, sales cycle, pricing power, and retention.',
    consumer:'A consumer investor would pressure-test acquisition loops, retention, trust, and marketplace liquidity.'
  }[persona] || '';
  const modeText = mode === 'plus' ? 'The offline trained model' : 'The basic rubric';
  const weak = Object.entries(sections).filter(([,v])=>v<40).map(([k])=>k.toLowerCase()).slice(0,3);
  const strong = Object.entries(sections).filter(([,v])=>v>=65).map(([k])=>k.toLowerCase()).slice(0,3);
  return `${modeText} gives this a ${score}/100 (${label}) with ${confidence.toLowerCase()} confidence. ${lens} Strongest areas: ${strong.length ? strong.join(', ') : 'not enough yet'}. Weakest areas: ${weak.length ? weak.join(', ') : 'mostly complete'}. The next improvement should be adding concrete proof, not more hype.`;
}

function makeQuestions(sections, persona) {
  const qs = [];
  if (sections.Traction < 55) qs.push('What evidence proves customers want this now?');
  if (sections.Market < 55) qs.push('Who is the first narrow customer segment and why now?');
  if (sections['Business model'] < 55) qs.push('How exactly do you make money and what are the margins?');
  if (sections.Moat < 55) qs.push('Why will this be hard to copy after competitors notice it?');
  if (persona === 'b2b') qs.push('Who signs the contract, what budget does it come from, and how long is the sales cycle?');
  if (persona === 'consumer') qs.push('What acquisition loop makes growth cheaper over time?');
  if (persona === 'friendly') qs.push('What founder insight makes you unusually likely to solve this?');
  if (qs.length < 4) qs.push('What milestone does this raise unlock in the next 12–18 months?');
  return qs.slice(0,5);
}

function makeDeckBullets(text, sections) {
  return [
    'Title: one-line description of what the company does.',
    'Problem: painful, specific, and urgent customer problem.',
    'Solution: simple product explanation with clear user benefit.',
    'Market: first beachhead plus larger market expansion path.',
    'Traction: strongest metric, pilot, revenue, usage, or waitlist proof.',
    'Business model: pricing, margin, or commission mechanics.',
    'Competition/moat: why you win and why it gets stronger over time.',
    'Team/ask: why this team, how much you are raising, and the milestone.'
  ];
}

