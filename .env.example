# Stripe secret key from Developers > API keys. The app also trims accidental spaces/quotes.

# Use Stripe recurring Price IDs (price_...), not Product IDs (prod_...).
# Product IDs are accepted only when the Stripe product has a default price.
STRIPE_DATA_PRICE_ID=price_1TZj6TDNYSgcRPsBLubJkP8G
STRIPE_PLUS_PRICE_ID=price_1TLrxyDNYSgcRPsBLVaXKk8I

# Public URL for checkout redirects and password reset links.
APP_URL=https://business-rating-ai.vercel.app/

# Long random string used to sign login sessions. Example: openssl rand -base64 32
AUTH_SECRET=iloveZoomie10!

# Password reset email delivery via Resend.
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL="Business Rating AI <noreply@yourdomain.com>"

# === SUPABASE (Analytics, Error Logging, Monitoring) ===
# Create a free Supabase project at https://supabase.com
# Then get these values from Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_here  # Keep secret, backend only
SUPABASE_ANON_KEY=anon_public_key_here       # Safe for client-side

# === ADMIN (Evaluation Runner, Monitoring Dashboard) ===
# Generate a random key: openssl rand -hex 32
# Used to protect /api/evaluate, /api/evaluation-results, /api/admin/*
# Pass as Bearer token in Authorization header
ADMIN_API_KEY=ADMIN_API_KEY
