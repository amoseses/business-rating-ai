# Stripe secret key from Stripe Dashboard > Developers > API keys.
# In Vercel, create a variable named STRIPE_SECRET_KEY and paste ONLY the sk_test_... or sk_live_... value.
# The app also accepts STRIPE_SECRET or STRIPE_API_KEY and trims accidental spaces/quotes/full STRIPE_SECRET_KEY=... pastes.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Use Stripe recurring Price IDs (price_...), not Product IDs (prod_...).
# Product IDs are accepted only when the Stripe product has a default price.
STRIPE_DATA_PRICE_ID=price_your_data_plan_price_id
STRIPE_PLUS_PRICE_ID=price_your_plus_plan_price_id

# Public URL for checkout redirects and password reset links.
APP_URL=https://your-vercel-domain.vercel.app

# Long random string used to sign login sessions. Example: openssl rand -base64 32
AUTH_SECRET=replace_with_a_long_random_secret

# Password reset email delivery via Resend.
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL="Business Rating AI <noreply@yourdomain.com>"
